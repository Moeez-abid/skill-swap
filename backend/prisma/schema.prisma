generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  SUPER_ADMIN
  MANAGER
  MAINTENANCE_ADMIN
}

enum AvailabilityStatus {
  AVAILABLE
  BUSY
  UNAVAILABLE
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum MatchRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  COMPLETED
  EXPIRED
}

enum SessionStatus {
  PROPOSED
  ACCEPTED
  DECLINED
  COUNTER_PROPOSED
  COMPLETED
  CANCELLED
}

enum MeetingMethod {
  VIDEO
  IN_PERSON
  PHONE
}

enum FlagStatus {
  PENDING
  RESOLVED
  DISMISSED
}

enum FlagTargetType {
  SKILL
  REVIEW
  USER
}

enum NotificationType {
  MESSAGE
  MATCH_REQUEST
  MATCH_ACCEPTED
  SESSION_PROPOSED
  SESSION_UPDATED
  SYSTEM
  GROUP_INVITE
}

enum DisputeStatus {
  PENDING_STANCES
  UNDER_REVIEW
  RESOLVED
}

enum GroupInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model User {
  id                    String             @id @default(cuid())
  email                 String             @unique
  passwordHash          String?
  googleId              String?            @unique
  name                  String
  headline              String?
  bio                   String?
  location              String?
  avatarUrl             String?
  linkedinUrl           String?
  githubUrl             String?
  portfolioUrl          String?
  timezone              String             @default("UTC")
  role                  UserRole           @default(USER)
  availabilityStatus    AvailabilityStatus @default(AVAILABLE)
  notifyMatches         Boolean            @default(true)
  notifyMessages        Boolean            @default(true)
  notifySessions        Boolean            @default(true)
  emailNotifyMatches    Boolean            @default(false)
  emailNotifyMessages   Boolean            @default(false)
  emailNotifySessions   Boolean            @default(true)
  isBanned              Boolean            @default(false)
  isVerified            Boolean            @default(false)
  verificationRequested Boolean            @default(false)
  bannedAt              DateTime?
  banReason             String?
  deletedAt             DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  skills                Skill[]
  wantedSkills          WantedSkill[]
  sentMatchRequests     MatchRequest[]     @relation("SentRequests")
  receivedMatchRequests MatchRequest[]     @relation("ReceivedRequests")
  activeMatchesAsUser1  ActiveMatch[]      @relation("MatchUser1")
  activeMatchesAsUser2  ActiveMatch[]      @relation("MatchUser2")
  messages              Message[]
  sessionsProposed      Session[]          @relation("SessionProposer")
  reviewsGiven          Review[]           @relation("ReviewsGiven")
  reviewsReceived       Review[]           @relation("ReviewsReceived")
  flagsCreated          Flag[]             @relation("FlagsCreated")
  auditLogs             AuditLog[]         @relation("AuditActor")
  auditLogsTarget       AuditLog[]         @relation("AuditTarget")
  disputesCreated       Dispute[]          @relation("DisputeCreator")
  disputesWon           Dispute[]          @relation("DisputeWinner")
  conversationsAsUser1  Conversation[]     @relation("ConversationUser1")
  conversationsAsUser2  Conversation[]     @relation("ConversationUser2")
  blocksCreated         Block[]            @relation("BlocksCreated")
  blocksReceived        Block[]            @relation("BlocksReceived")

  notifications         Notification[]     @relation("UserNotifications")
  blogPosts             BlogPost[]
  blogComments          BlogComment[]
  createdGroups         Group[]            @relation("GroupCreator")
  groupMemberships      GroupMember[]
  groupMessages         GroupMessage[]
  groupInvitesSent      GroupInvitation[]  @relation("GroupInvitesSent")
  groupInvitesReceived  GroupInvitation[]  @relation("GroupInvitesReceived")

  @@index([email])
  @@index([role])
}

model Category {
  id            String        @id @default(cuid())
  name          String        @unique
  slug          String        @unique
  icon          String?
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  subcategories Subcategory[]
  skills        Skill[]
}

model Subcategory {
  id         String   @id @default(cuid())
  name       String
  slug       String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  skills     Skill[]

  @@unique([categoryId, slug])
}

model Skill {
  id               String             @id @default(cuid())
  title            String
  level            SkillLevel
  shortDescription String
  fullDescription  String
  learningOutcomes String
  prerequisites    String?
  sessionDurations Int[]
  coverImageUrl    String?
  availability     AvailabilityStatus @default(AVAILABLE)
  requestCount     Int                @default(0)
  viewCount        Int                @default(0)
  avgRating        Float              @default(0)
  reviewCount      Int                @default(0)
  isFeatured       Boolean            @default(false)
  isFlagged        Boolean            @default(false)
  isDeleted        Boolean            @default(false)
  providerId       String
  categoryId       String
  subcategoryId    String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  provider         User               @relation(fields: [providerId], references: [id], onDelete: Cascade)
  category         Category           @relation(fields: [categoryId], references: [id])
  subcategory      Subcategory        @relation(fields: [subcategoryId], references: [id])
  tags             SkillTag[]
  schedules        SkillSchedule[]
  offeredInRequests MatchRequest[]    @relation("OfferedSkill")
  wantedInRequests  MatchRequest[]   @relation("WantedSkill")

  @@index([categoryId])
  @@index([level])
  @@index([createdAt])
  @@index([requestCount])
  @@index([avgRating])
}

model Tag {
  id     String     @id @default(cuid())
  name   String     @unique
  skills SkillTag[]
}

model SkillTag {
  skillId String
  tagId   String
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([skillId, tagId])
}

model SkillSchedule {
  id        String @id @default(cuid())
  skillId   String
  dayOfWeek Int
  startTime String
  endTime   String
  skill     Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
}

model WantedSkill {
  id          String     @id @default(cuid())
  title       String
  level       SkillLevel?
  description String?
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
}

model MatchRequest {
  id             String             @id @default(cuid())
  message        String
  status         MatchRequestStatus @default(PENDING)
  senderId       String
  receiverId     String
  offeredSkillId String
  wantedSkillId  String
  offeredSkillSnapshot Json?
  wantedSkillSnapshot  Json?
  expiresAt      DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  sender         User               @relation("SentRequests", fields: [senderId], references: [id])
  receiver       User               @relation("ReceivedRequests", fields: [receiverId], references: [id])
  offeredSkill   Skill              @relation("OfferedSkill", fields: [offeredSkillId], references: [id])
  wantedSkill    Skill              @relation("WantedSkill", fields: [wantedSkillId], references: [id])
  activeMatch    ActiveMatch?

  @@index([senderId])
  @@index([receiverId])
  @@index([status])
}

model ActiveMatch {
  id             String       @id @default(cuid())
  matchRequestId String       @unique
  user1Id        String
  user2Id        String
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  matchRequest   MatchRequest @relation(fields: [matchRequestId], references: [id])
  user1          User         @relation("MatchUser1", fields: [user1Id], references: [id])
  user2          User         @relation("MatchUser2", fields: [user2Id], references: [id])
  conversation   Conversation?
  sessions       Session[]
  reviews        Review[]
  dispute        Dispute?

  @@index([user1Id])
  @@index([user2Id])
}

model Conversation {
  id            String       @id @default(cuid())
  user1Id       String
  user2Id       String
  activeMatchId String?      @unique
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  activeMatch   ActiveMatch? @relation(fields: [activeMatchId], references: [id], onDelete: Cascade)
  user1         User         @relation("ConversationUser1", fields: [user1Id], references: [id])
  user2         User         @relation("ConversationUser2", fields: [user2Id], references: [id])
  messages      Message[]

  @@unique([user1Id, user2Id])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String?
  fileUrl        String?
  fileName       String?
  fileType       String?
  isRead         Boolean      @default(false)
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  deletedFor     String[]     @default([])

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id])
  replyToId      String?
  replyTo        Message?     @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies        Message[]    @relation("MessageReplies")

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

model Session {
  id              String        @id @default(cuid())
  activeMatchId   String
  proposerId      String
  scheduledStart  DateTime
  scheduledEnd    DateTime
  durationMinutes Int
  agenda          String?
  meetingMethod   MeetingMethod @default(VIDEO)
  meetingDetails  String?
  status          SessionStatus @default(PROPOSED)
  counterStart    DateTime?
  counterEnd      DateTime?
  reminderSent    Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  activeMatch     ActiveMatch   @relation(fields: [activeMatchId], references: [id], onDelete: Cascade)
  proposer        User          @relation("SessionProposer", fields: [proposerId], references: [id])
  reviews         Review[]

  @@index([activeMatchId])
  @@index([scheduledStart])
  @@index([status])
}

model Review {
  id                   String   @id @default(cuid())
  sessionId            String?
  activeMatchId        String?
  reviewerId           String
  revieweeId           String
  ratingOverall        Int
  ratingTeaching       Int
  ratingCommunication  Int
  ratingPunctuality    Int
  feedback             String
  wasMissed            Boolean  @default(false)
  isRevealed           Boolean  @default(false)
  lockedAt             DateTime?
  createdAt            DateTime @default(now())

  session              Session?      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  activeMatch          ActiveMatch?  @relation(fields: [activeMatchId], references: [id], onDelete: Cascade)
  reviewer             User          @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewee             User          @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  @@unique([sessionId, reviewerId])
  @@unique([activeMatchId, reviewerId])
  @@index([revieweeId])
}

model Flag {
  id          String         @id @default(cuid())
  targetType  FlagTargetType
  targetId    String
  reason      String
  status      FlagStatus     @default(PENDING)
  reporterId  String
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())

  reporter    User           @relation("FlagsCreated", fields: [reporterId], references: [id])

  @@index([status])
  @@index([targetType, targetId])
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  actorId    String
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor      User     @relation("AuditActor", fields: [actorId], references: [id])
  target     User?    @relation("AuditTarget", fields: [targetId], references: [id])

  @@index([actorId])
  @@index([createdAt])
}

model Dispute {
  id             String        @id @default(cuid())
  activeMatchId  String        @unique
  creatorId      String
  status         DisputeStatus @default(PENDING_STANCES)
  deadline       DateTime
  
  user1Stance    String?
  user2Stance    String?
  
  decision       String?
  winnerId       String?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  activeMatch    ActiveMatch   @relation(fields: [activeMatchId], references: [id], onDelete: Cascade)
  creator        User          @relation("DisputeCreator", fields: [creatorId], references: [id])
  winner         User?         @relation("DisputeWinner", fields: [winnerId], references: [id])

  @@index([activeMatchId])
  @@index([status])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  content   String
  linkUrl   String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user      User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([isRead])
}

model SupportMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model BlogPost {
  id            String        @id @default(cuid())
  title         String
  content       String
  coverImageUrl String?
  authorId      String
  author        User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  comments      BlogComment[]

  @@index([authorId])
  @@index([createdAt])
}

model BlogComment {
  id        String        @id @default(cuid())
  content   String
  postId    String
  post      BlogPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    BlogComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   BlogComment[] @relation("CommentReplies")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
  @@index([createdAt])
}

model Group {
  id            String         @id @default(cuid())
  name          String
  description   String
  messagingMode String         @default("ALL")
  creatorId     String
  creator       User           @relation("GroupCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  members       GroupMember[]
  messages      GroupMessage[]
  invitations   GroupInvitation[]

  @@index([creatorId])
}

model GroupInvitation {
  id        String                @id @default(cuid())
  groupId   String
  inviterId String
  inviteeId String
  status    GroupInvitationStatus @default(PENDING)
  createdAt DateTime              @default(now())

  group     Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  inviter   User  @relation("GroupInvitesSent", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee   User  @relation("GroupInvitesReceived", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@unique([groupId, inviteeId])
  @@index([inviteeId])
}

model GroupMember {
  groupId  String
  userId   String
  role     String   @default("MEMBER")
  joinedAt DateTime @default(now())
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

model GroupMessage {
  id         String   @id @default(cuid())
  groupId    String
  senderId   String
  content    String?
  fileUrl    String?
  fileName   String?
  fileType   String?
  replyToId  String?
  deletedFor String[] @default([])
  createdAt  DateTime @default(now())

  group      Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sender     User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo    GroupMessage? @relation("GroupMessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies    GroupMessage[] @relation("GroupMessageReplies")

  @@index([groupId])
  @@index([senderId])
  @@index([createdAt])
}

model Block {
  id          String   @id @default(cuid())
  blockerId   String
  blockedId   String
  reason      String?
  createdAt   DateTime @default(now())

  blocker     User     @relation("BlocksCreated", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedUser User     @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}
